# Local development (outside Docker): use localhost
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/laptops

# Inside Docker Compose: use the service name 'db' as host (set in compose.yaml)
# DATABASE_URL=mysql+pymysql://root:yourpassword@db:3306/laptops

DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/laptops
DEBUG=false

# MariaDB root password — substituted into compose.yaml at runtime.
MYSQL_ROOT_PASSWORD=yourpassword

# Authentication (single shared login).
# Generate SESSION_SECRET with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
SESSION_SECRET=replace-with-a-random-32-byte-hex-string
